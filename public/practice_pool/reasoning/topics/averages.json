    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "The average of 5 numbers is 18. If one number is excluded, the average becomes 16. What is the excluded number?",
    "options": [
      {
        "id": "A",
        "text": "26"
      },
      {
        "id": "B",
        "text": "24"
      },
      {
        "id": "C",
        "text": "22"
      },
      {
        "id": "D",
        "text": "20"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "26",
      "explanation": {
        "concept": "Average = Sum / Number of elements. Removing one element changes the total sum.",
        "step_by_step": [
          "Total sum of 5 numbers = 5 × 18 = 90",
          "Sum of remaining 4 numbers = 4 × 16 = 64",
          "Excluded number = 90 − 64 = 26"
        ],
        "why_correct": {
          "A": "26 satisfies the difference between total and remaining sum"
        },
        "why_incorrect": {
          "B": "24 gives incorrect difference",
          "C": "22 does not match computed sum difference",
          "D": "20 is too small compared to required difference"
        }
      }
    },
