    "answer_type": "single_correct",
    "question_text": "A line graph shows the sales (in thousands) of a company from 2015 to 2020 as: 2015=40, 2016=50, 2017=65, 2018=55, 2019=70, 2020=90. What is the percentage increase in sales from 2015 to 2020?",
    "options": [
      {
        "id": "A",
        "text": "125%"
      },
      {
        "id": "B",
        "text": "150%"
      },
      {
        "id": "C",
        "text": "120%"
      },
      {
        "id": "D",
        "text": "130%"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "125%",
      "explanation": {
        "concept": "Percentage increase = (Final - Initial) / Initial × 100.",
        "step_by_step": [
          "Initial value = 40, Final value = 90",
          "Increase = 90 - 40 = 50",
          "Percentage increase = (50 / 40) × 100 = 125%"
        ],
        "why_correct": {
          "A": "Correct calculation of percentage increase."
        },
        "why_incorrect": {
          "B": "Overestimates the increase.",
          "C": "Incorrect denominator usage.",
          "D": "Miscalculation of percentage."
        }
      }
    },
