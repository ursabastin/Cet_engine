    "question_text": "Statements: X = Y, Y \u2265 Z, Z > W\nConclusion I: X > W\nConclusion II: Y = Z",
    "options": [
      { "id": "A", "text": "Only I follows" },
      { "id": "B", "text": "Only II follows" },
      { "id": "C", "text": "Both I and II follow" },
      { "id": "D", "text": "Neither I nor II follows" }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "Only I follows",
      "explanation": {
        "concept": "Definite vs Possible",
        "step_by_step": [
          "X = Y \u2265 Z > W means X > W (definite, I follows).",
          "Y \u2265 Z means Y is either greater than OR equal to Z; Y = Z is only one possibility, not a definite conclusion (II doesn't follow)."
        ]
      }
    },
    "question_state": "active"
