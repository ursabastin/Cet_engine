    "difficulty": { "level": 3, "label": "basic" },
    "question_text": "Statements: A > B, B = C, C < D\nConclusion I: A > C\nConclusion II: B < D",
    "options": [
      { "id": "A", "text": "Only I follows" },
      { "id": "B", "text": "Only II follows" },
      { "id": "C", "text": "Both I and II follow" },
      { "id": "D", "text": "Neither I nor II follows" }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Both I and II follow",
      "explanation": {
        "concept": "Basic Inequalities",
        "step_by_step": [
          "Since B = C, A > B implies A > C (I follows).",
          "Since B = C and C < D, B < D (II follows)."
        ]
      }
    },
    "question_state": "active"
