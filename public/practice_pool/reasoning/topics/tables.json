    "question_text": "A table shows production of units over 3 months: Jan=200, Feb=240, Mar=300. What is the average percentage growth per month (approx)?",
    "options": [
      {
        "id": "A",
        "text": "20%"
      },
      {
        "id": "B",
        "text": "22%"
      },
      {
        "id": "C",
        "text": "25%"
      },
      {
        "id": "D",
        "text": "30%"
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "22%",
      "explanation": {
        "concept": "Compute percentage growth month-wise then average",
        "step_by_step": [
          "Jan→Feb growth = (240−200)/200 = 20%",
          "Feb→Mar growth = (300−240)/240 = 25%",
          "Average = (20+25)/2 = 22.5 ≈ 22%"
        ],
        "why_correct": {
          "B": "Closest approximation"
        },
        "why_incorrect": {
          "A": "Only first growth considered",
          "C": "Only second growth considered",
          "D": "Overestimation"
