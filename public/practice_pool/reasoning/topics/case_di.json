    "confidence_score": 0.91,
    "metadata": {
      "estimated_time_sec": 80,
      "concepts": [
        "set theory",
        "inclusion exclusion"
      ],
      "formulae": [
        "Only A = A - (A ∩ B)"
      ]
    },
