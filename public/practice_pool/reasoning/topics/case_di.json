    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "In a survey of 500 people, 60% like tea, 50% like coffee, and 30% like both. If 10% like neither, how many people like only tea?",
    "options": [
      {
        "id": "A",
        "text": "150"
      },
      {
        "id": "B",
        "text": "180"
      },
      {
        "id": "C",
        "text": "200"
      },
      {
        "id": "D",
        "text": "120"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "150",
      "explanation": {
        "concept": "Set theory with overlapping groups using inclusion-exclusion principle.",
        "step_by_step": [
          "Total = 500",
          "Tea = 60% of 500 = 300",
          "Both = 30% of 500 = 150",
          "Only tea = Tea - Both = 300 - 150 = 150"
        ],
        "why_correct": {
          "A": "150 correctly subtracts overlapping group."
        },
        "why_incorrect": {
          "B": "180 assumes incorrect overlap subtraction.",
          "C": "200 ignores intersection.",
          "D": "120 is arbitrary without correct logic."
        }
      }
    },
    "question_state": "active",
