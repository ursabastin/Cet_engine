        "text": "48"
      },
      {
        "id": "D",
        "text": "54"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "72",
      "explanation": {
        "concept": "Sequential percentage reduction where each department takes a portion of the remaining employees.",
        "step_by_step": [
          "Total employees = 200",
          "A = 20% of 200 = 40 → remaining = 160",
          "B = 25% of 160 = 40 → remaining = 120",
          "C = 40% of 120 = 48 → remaining = 72",
          "D = remaining = 72"
        ],
        "why_correct": {
          "A": "72 is the final remaining number after successive allocations."
        },
        "why_incorrect": {
          "B": "60 assumes incorrect percentage application.",
          "C": "48 corresponds to department C, not D.",
          "D": "54 results from incorrect sequential deduction."
        }
      }
    },
