    "answer_type": "single_correct",
    "question_text": "Statements: All pens are books. Some books are tables.\nConclusions:\nI. Some pens are tables.\nII. Some tables are pens.\nWhich of the conclusions logically follow?",
    "options": [
      {
        "id": "A",
        "text": "Only I follows"
      },
      {
        "id": "B",
        "text": "Only II follows"
      },
      {
        "id": "C",
        "text": "Both I and II follow"
      },
      {
        "id": "D",
        "text": "Neither I nor II follows"
      }
    ],
    "correct_option": "D",
    "solution": {
      "final_answer": "Neither I nor II follows",
      "explanation": {
        "concept": "In syllogism, when two statements connect via a middle term but lack definite intersection, conclusions involving extremes are not guaranteed.",
        "step_by_step": [
          "All pens ⊆ books",
          "Some books ∩ tables exists",
          "No direct relation between pens and tables is established",
          "Hence, no definite conclusion can be drawn about pens and tables"
        ],
        "why_correct": {
          "A": "Correct because no definite relation between pens and tables is established"
        },
        "why_incorrect": {
          "B": "Assumes reverse relation without evidence",
          "C": "Both rely on unjustified linkage",
          "D": "Correct choice as neither conclusion is definite"
        }
      }
    },
