  {
    "id": 8401,
    "subject": "Logical Reasoning",
    "topic": "Data Sufficiency",
    "difficulty": { "level": 4, "label": "moderate" },
    "question_text": "What is the age of Ravi?\nStatement 1: Ravi is 5 years younger than his sister, Priya.\nStatement 2: Priya will be 30 years old in 2 years.",
    "options": [
      { "id": "A", "text": "Statement 1 alone is sufficient" },
      { "id": "B", "text": "Statement 2 alone is sufficient" },
      { "id": "C", "text": "Both statements together are sufficient" },
      { "id": "D", "text": "Neither statement is sufficient" }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Both statements together are sufficient",
      "explanation": {
        "concept": "Data Sufficiency (Ages)",
        "step_by_step": [
          "From 2: Priya is 28 now.",
          "From 1: Ravi is 28 - 5 = 23.",
          "Both are needed to find the exact age."
        ]
      }
    },
    "question_state": "active"
  },
  {
