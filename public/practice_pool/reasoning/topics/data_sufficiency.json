  {
    "id": 8404,
    "subject": "Logical Reasoning",
    "topic": "Data Sufficiency",
    "difficulty": { "level": 4, "label": "moderate" },
    "question_text": "How many students are there in the class?\nStatement 1: Amit's rank is 10th from the top.\nStatement 2: Amit's rank is 20th from the bottom.",
    "options": [
      { "id": "A", "text": "Statement 1 alone is sufficient" },
      { "id": "B", "text": "Statement 2 alone is sufficient" },
      { "id": "C", "text": "Both together are sufficient" },
      { "id": "D", "text": "Neither is sufficient" }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Both together are sufficient",
      "explanation": {
        "concept": "Ranking Logic",
        "step_by_step": [
          "Total = Rank from top + Rank from bottom - 1.",
          "Total = 10 + 20 - 1 = 29."
        ]
      }
    },
    "question_state": "active"
  },
