      { "id": "A", "text": "Statement 1 alone is sufficient" },
      { "id": "B", "text": "Statement 2 alone is sufficient" },
      { "id": "C", "text": "Both together are sufficient" },
      { "id": "D", "text": "Neither is sufficient" }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Both together are sufficient",
      "explanation": {
