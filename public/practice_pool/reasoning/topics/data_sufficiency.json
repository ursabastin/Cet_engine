      { "id": "C", "text": "Either statement alone is sufficient" },
      { "id": "D", "text": "Neither statement is sufficient" }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Either statement alone is sufficient",
      "explanation": {
        "concept": "Number Properties",
        "step_by_step": [
          "Multiples of 6 (6, 12, 18...) are always even.",
          "Multiples of 4 (4, 8, 12...) are always even.",
          "So, either statement can independently answer 'Yes'."
        ]
      }
    },
    "question_state": "active"
