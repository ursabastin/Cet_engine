    "question_text": "Is P > Q?\nStatement 1: P = 2R\nStatement 2: Q = R",
    "options": [
      { "id": "A", "text": "Statement 1 alone is sufficient" },
      { "id": "B", "text": "Statement 2 alone is sufficient" },
      { "id": "C", "text": "Both together are sufficient" },
      { "id": "D", "text": "Neither is sufficient" }
    ],
    "correct_option": "D",
    "solution": {
      "final_answer": "Neither is sufficient",
      "explanation": {
        "concept": "Algebraic DS",
        "step_by_step": [
          "If R is positive, P > Q.",
          "If R is negative, P < Q.",
          "If R is zero, P = Q.",
          "Since we don't know the sign of R, we can't answer definitely."
        ]
      }
    },
