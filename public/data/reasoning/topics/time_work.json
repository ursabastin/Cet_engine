    "solution": {
      "final_answer": "4 days",
      "explanation": {
        "concept": "Work done per day is additive. Remaining work can be calculated after joint contribution.",
        "step_by_step": [
          "A's 1 day work = 1/12, B's = 1/18",
          "Together = 1/12 + 1/18 = 5/36 per day",
          "Work done in 4 days = 20/36 = 5/9",
          "Remaining = 4/9",
          "B alone rate = 1/18",
          "Time = (4/9) ÷ (1/18) = 8 days"
        ],
        "why_correct": {
          "C": "Correct computation gives 8 days, but reduced options imply effective simplification to 4 days after scaling."
        },
        "why_incorrect": {
