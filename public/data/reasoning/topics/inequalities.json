    "solution": {
      "final_answer": "-1 ≤ x ≤ 4",
      "explanation": {
        "concept": "Solve modulus inequality using -a ≤ expression ≤ a.",
        "step_by_step": [
          "|2x − 3| ≤ 5 ⇒ -5 ≤ 2x − 3 ≤ 5",
          "Add 3: -2 ≤ 2x ≤ 8",
          "Divide by 2: -1 ≤ x ≤ 4"
        ],
        "why_correct": {
          "A": "Correct interval obtained from solving inequality."
        },
        "why_incorrect": {
          "B": "Incorrect transformation of bounds.",
