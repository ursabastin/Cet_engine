    "answer_type": "single_correct",
    "question_text": "If a, b, c are positive real numbers such that a + b + c = 6, then the maximum value of ab + bc + ca is:",
    "options": [
      {
        "id": "A",
        "text": "12"
      },
      {
        "id": "B",
        "text": "9"
      },
      {
        "id": "C",
        "text": "18"
      },
      {
        "id": "D",
        "text": "6"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "12",
      "explanation": {
        "concept": "Use symmetry and inequality principle: for fixed sum, pairwise product is maximized when variables are equal.",
        "step_by_step": [
          "Given a + b + c = 6",
          "For maximum ab + bc + ca, take a = b = c (by symmetry and AM-GM reasoning)",
          "So a = b = c = 2",
          "Compute: ab + bc + ca = 2×2 + 2×2 + 2×2 = 4 + 4 + 4 = 12"
        ],
        "why_correct": {
          "A": "Maximum occurs at equality, giving value 12."
        },
        "why_incorrect": {
          "B": "Too low; occurs when variables are unequal.",
          "C": "Exceeds possible bound under fixed sum.",
          "D": "Minimum-type value, not maximum."
        }
      }
    },
