    "solution": {
      "final_answer": "44%",
      "explanation": {
        "concept": "Area of a circle is proportional to the square of its radius (A ∝ r²).",
        "step_by_step": [
          "Let original radius = r",
          "New radius = 1.2r",
          "New area = π(1.2r)^2 = 1.44πr^2",
          "Increase = 1.44 - 1 = 0.44 = 44%"
        ],
        "why_correct": {
          "A": "Incorrect because area does not increase linearly with radius."
        },
        "why_incorrect": {
