    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "A study finds that students who study at night score higher on exams. Which assumption is necessary for the conclusion that studying at night improves performance?",
    "options": [
      {
        "id": "A",
        "text": "Night study students sleep fewer hours."
      },
      {
        "id": "B",
        "text": "Students who study at night are not inherently more motivated."
      },
      {
        "id": "C",
        "text": "Daytime studying is less effective."
      },
      {
        "id": "D",
        "text": "Exam difficulty is uniform."
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "B",
      "explanation": {
        "concept": "Necessary assumption eliminates alternative explanations.",
        "step_by_step": [
          "Conclusion assumes night study causes better performance.",
          "Alternative: motivated students choose night study.",
          "If true, causation fails.",
          "So assumption must deny this alternative."
        ],
        "why_correct": {
          "B": "Removes alternative explanation."
        },
        "why_incorrect": {
          "A": "Irrelevant to causation.",
          "C": "Not required assumption.",
          "D": "Not essential for argument."
        }
      }
    },
