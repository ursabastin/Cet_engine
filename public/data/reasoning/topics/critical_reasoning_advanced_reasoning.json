    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "An analyst argues that because sales increased after the advertising campaign, the campaign must have caused the increase. Which of the following identifies the most critical flaw in the reasoning?",
    "options": [
      {
        "id": "A",
        "text": "Fails to consider that correlation does not imply causation."
      },
      {
        "id": "B",
        "text": "Assumes that sales cannot decrease after advertising."
      },
      {
        "id": "C",
        "text": "Ignores the possibility of seasonal demand fluctuations."
      },
      {
        "id": "D",
        "text": "Assumes that advertising campaigns are always effective."
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "A",
      "explanation": {
        "concept": "Post hoc fallacy—assuming causation from sequence.",
        "step_by_step": [
          "Observation: Sales increased after campaign.",
          "Conclusion: Campaign caused increase.",
          "This ignores possibility of coincidence or external factors.",
          "This is classic correlation vs causation error."
        ],
        "why_correct": {
          "A": "Correctly identifies core flaw in reasoning."
        },
        "why_incorrect": {
          "B": "Not discussed in argument.",
          "C": "Specific alternative, but not core flaw.",
          "D": "Not assumed explicitly."
        }
      }
    },
