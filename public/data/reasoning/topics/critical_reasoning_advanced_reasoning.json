    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "An argument states: 'If the product quality improves, sales will increase. Sales did not increase. Therefore, product quality did not improve.' Identify the reasoning.",
    "options": [
      {
        "id": "A",
        "text": "Modus ponens"
      },
      {
        "id": "B",
        "text": "Modus tollens"
      },
      {
        "id": "C",
        "text": "Affirming the consequent"
      },
      {
        "id": "D",
        "text": "Denying the antecedent"
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "B",
      "explanation": {
        "concept": "Modus tollens: If P → Q, ¬Q ⇒ ¬P.",
        "step_by_step": [
          "Given: If P then Q.",
          "Given: Not Q.",
          "Conclusion: Not P.",
          "This is modus tollens."
        ],
        "why_correct": {
          "B": "Matches logical structure."
        },
        "why_incorrect": {
          "A": "Requires P true.",
          "C": "Different fallacy.",
          "D": "Different invalid form."
        }
      }
    },
