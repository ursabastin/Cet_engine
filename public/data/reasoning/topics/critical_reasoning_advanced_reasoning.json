    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "A company claims that implementing flexible working hours has increased employee productivity because overall project completion time has decreased by 15%. Which of the following, if true, most seriously weakens this conclusion?",
    "options": [
      {
        "id": "A",
        "text": "Employees reported higher job satisfaction after flexible hours were introduced."
      },
      {
        "id": "B",
        "text": "The company hired additional temporary staff during the same period."
      },
      {
        "id": "C",
        "text": "Flexible working hours were optional for employees."
      },
      {
        "id": "D",
        "text": "Project complexity remained unchanged during the period."
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "B",
      "explanation": {
        "concept": "Weakening questions require identifying alternative causes that explain the observed effect.",
        "step_by_step": [
          "Conclusion: Flexible hours caused improved productivity.",
          "Look for alternative explanations for reduced completion time.",
          "Hiring additional staff could reduce completion time independently.",
          "This undermines the causal link between flexible hours and productivity."
        ],
        "why_correct": {
          "A": "Incorrect because satisfaction does not directly challenge productivity claim.",
          "B": "Correct because additional staff is an alternative explanation for faster completion.",
          "C": "Irrelevant to causation.",
          "D": "Supports consistency but does not weaken argument."
        },
        "why_incorrect": {
          "A": "Does not contradict or weaken the claim.",
          "C": "Does not provide alternative explanation.",
          "D": "Actually strengthens reliability of comparison."
        }
      }
    },
