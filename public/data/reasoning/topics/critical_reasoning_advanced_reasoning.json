    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "All the employees who attended the training improved their performance. Some employees who did not attend the training also improved their performance. Which conclusion logically follows?",
    "options": [
      {
        "id": "A",
        "text": "Training is the only factor responsible for performance improvement."
      },
      {
        "id": "B",
        "text": "Some employees improved performance without attending training."
      },
      {
        "id": "C",
        "text": "No employee who skipped training improved performance."
      },
      {
        "id": "D",
        "text": "All employees improved performance."
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "B",
      "explanation": {
        "concept": "Syllogistic reasoning involving overlapping sets.",
        "step_by_step": [
          "Given: All trained employees improved.",
          "Given: Some untrained employees also improved.",
          "This directly implies improvement without training is possible.",
          "Thus, option B is valid."
        ],
        "why_correct": {
          "B": "Directly derived from second statement."
        },
        "why_incorrect": {
          "A": "Contradicted by second statement.",
          "C": "Opposite of given information.",
          "D": "Not supported; only 'some' improved."
        }
      }
    },
