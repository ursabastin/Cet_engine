    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "If the statement 'All efficient managers are good communicators' is true, which of the following must also be true?",
    "options": [
      {
        "id": "A",
        "text": "All good communicators are efficient managers."
      },
      {
        "id": "B",
        "text": "Some good communicators are efficient managers."
      },
      {
        "id": "C",
        "text": "No inefficient manager is a good communicator."
      },
      {
        "id": "D",
        "text": "Some efficient managers may not be good communicators."
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "B",
      "explanation": {
        "concept": "Logical implication and set inclusion.",
        "step_by_step": [
          "Given: Efficient managers ⊆ good communicators.",
          "This implies at least those efficient managers are good communicators.",
          "So, some good communicators are efficient managers.",
          "Thus B is valid."
        ],
        "why_correct": {
          "B": "Follows directly from subset relationship."
        },
        "why_incorrect": {
          "A": "Reverses relationship.",
          "C": "Not necessarily true.",
          "D": "Contradicts given statement."
        }
      }
    },
