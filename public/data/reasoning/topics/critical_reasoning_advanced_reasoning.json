    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "If all A are B, and no B are C, which of the following must be true?",
    "options": [
      {
        "id": "A",
        "text": "No A are C."
      },
      {
        "id": "B",
        "text": "Some A are C."
      },
      {
        "id": "C",
        "text": "All C are A."
      },
      {
        "id": "D",
        "text": "Some B are A."
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "A",
      "explanation": {
        "concept": "Transitive exclusion in set theory.",
        "step_by_step": [
          "A ⊆ B",
          "B ∩ C = ∅",
          "Thus A cannot overlap with C.",
          "So, no A are C."
        ],
        "why_correct": {
          "A": "Direct logical implication."
        },
        "why_incorrect": {
          "B": "Contradicts logic.",
          "C": "Unsupported reversal.",
          "D": "Not necessarily true."
        }
      }
    },
