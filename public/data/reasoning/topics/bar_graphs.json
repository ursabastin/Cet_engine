        "id": "D",
        "text": "170"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "140",
      "explanation": {
        "concept": "Average = total values ÷ number of observations.",
        "step_by_step": [
          "Total = 120+150+180+90+160 = 700",
          "Average = 700/5 = 140"
