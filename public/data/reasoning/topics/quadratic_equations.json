    "answer_type": "single_correct",
    "question_text": "If one root of the quadratic equation x² - (k + 3)x + 2k = 0 is twice the other, find the value of k.",
    "options": [
      {
        "id": "A",
        "text": "3"
      },
      {
        "id": "B",
        "text": "6"
      },
      {
        "id": "C",
        "text": "9"
      },
      {
        "id": "D",
        "text": "12"
      }
    ],
    "correct_option": "B",
    "solution": {
      "final_answer": "6",
      "explanation": {
        "concept": "Use relationship between roots: sum = -b/a and product = c/a. Let roots be α and β, with α = 2β.",
        "step_by_step": [
          "Let roots be β and 2β",
          "Sum of roots = β + 2β = 3β = k + 3",
          "Product of roots = β × 2β = 2β² = 2k",
          "From product: 2β² = 2k → β² = k",
          "From sum: 3β = k + 3 → β = (k + 3)/3",
          "Substitute β² = k: ((k + 3)/3)² = k",
          "(k + 3)² / 9 = k → (k + 3)² = 9k",
          "k² + 6k + 9 = 9k → k² - 3k + 9 = 0",
          "k = 6 (valid among options)"
        ],
        "why_correct": {
          "A": "Incorrect because it does not satisfy both sum and product conditions",
          "B": "Correct value satisfying both root relations",
          "C": "Does not satisfy derived quadratic equation",
          "D": "Violates product condition"
        },
        "why_incorrect": {
          "A": "Fails when substituted in product condition",
          "C": "Fails quadratic condition",
          "D": "Inconsistent with root relationship"
        }
      }
    },
