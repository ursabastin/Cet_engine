        "id": "A",
        "text": "24 cm"
      },
      {
        "id": "B",
        "text": "20 cm"
      },
      {
        "id": "C",
        "text": "18 cm"
      },
      {
        "id": "D",
        "text": "22 cm"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "24 cm",
      "explanation": {
        "concept": "Perpendicular from center to chord bisects the chord. Use right triangle with radius as hypotenuse.",
        "step_by_step": [
          "Half chord = sqrt(r^2 - d^2) = sqrt(169 - 25) = sqrt(144) = 12",
          "Full chord = 2 × 12 = 24"
        ],
        "why_correct": {
          "A": "Correct calculation gives 24 cm"
        },
        "why_incorrect": {
          "B": "Incorrect subtraction or square root",
          "C": "Arithmetic mistake",
          "D": "Wrong use of formula"
        }
      }
