    "answer_type": "single_correct",
    "question_text": "Statements:\nI. Heavy rainfall occurred in the region for five consecutive days.\nII. Several villages in the region were flooded.\n\nWhich of the following is correct?",
    "options": [
      {
        "id": "A",
        "text": "I is the cause and II is the effect"
      },
      {
        "id": "B",
        "text": "II is the cause and I is the effect"
      },
      {
        "id": "C",
        "text": "Both are independent effects of a common cause"
      },
      {
        "id": "D",
        "text": "Both are independent causes"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "I is the cause and II is the effect",
      "explanation": {
        "concept": "Cause & Effect reasoning identifies whether one statement logically leads to another.",
        "step_by_step": [
          "Heavy rainfall logically leads to water accumulation.",
          "Flooding is a direct consequence of excessive rainfall.",
          "Thus, rainfall causes flooding."
        ],
        "why_correct": {
          "A": "Heavy rainfall directly results in flooding."
        },
        "why_incorrect": {
          "B": "Flooding cannot cause rainfall.",
          "C": "Flooding is not independent; it follows rainfall.",
          "D": "Flooding is not a cause here."
        }
      }
    },
