    "correct_option": "B",
    "solution": {
      "final_answer": "¬P ∨ ¬Q",
      "explanation": {
        "concept": "De Morgan’s Laws state that negation of conjunction becomes disjunction of negations.",
        "step_by_step": [
          "Given expression: ¬(P ∧ Q)",
          "Apply De Morgan’s Law",
          "Result: ¬P ∨ ¬Q"
        ],
        "why_correct": {
          "A": "Incorrect, this is stronger than original statement",
          "B": "Correct application of De Morgan’s Law",
          "C": "No negation applied",
          "D": "Implication is unrelated"
        },
        "why_incorrect": {
          "A": "Conjunction instead of disjunction",
          "C": "Does not involve negation",
          "D": "Different connective entirely"
        }
