    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "A bag contains 5 red, 4 blue, and 3 green balls. Two balls are drawn sequentially without replacement. What is the probability that the second ball is blue given that the first ball drawn was red?",
    "options": [
      {
        "id": "A",
        "text": "4/11"
      },
      {
        "id": "B",
        "text": "2/5"
      },
      {
        "id": "C",
        "text": "4/12"
      },
      {
        "id": "D",
        "text": "5/11"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "4/11",
      "explanation": {
        "concept": "Conditional probability: P(B2 | R1) = remaining favorable outcomes over remaining total outcomes.",
        "step_by_step": [
          "Initially total balls = 12.",
          "Given first ball is red, remaining balls = 11.",
          "Blue balls remain = 4.",
          "Probability = 4/11."
        ],
        "why_correct": {
          "A": "Correctly accounts for reduced total and unchanged blue count."
        },
        "why_incorrect": {
          "B": "Incorrect fraction simplification and ignores conditional context.",
          "C": "Incorrect denominator, total becomes 11 not 12.",
          "D": "Uses red count instead of blue."
        }
      }
    },
    "question_state": "active",
