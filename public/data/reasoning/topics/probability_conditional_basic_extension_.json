    "question_type": "MCQ",
    "answer_type": "single_correct",
    "question_text": "A student answers a multiple-choice question correctly with probability 0.6. Given that he did not guess randomly, what is the probability he knew the answer if probability of knowing is 0.5?",
    "options": [
      {
        "id": "A",
        "text": "5/6"
      },
      {
        "id": "B",
        "text": "2/3"
      },
      {
        "id": "C",
        "text": "3/5"
      },
      {
        "id": "D",
        "text": "4/5"
      }
    ],
    "correct_option": "D",
    "solution": {
      "final_answer": "4/5",
      "explanation": {
        "concept": "Bayesian conditional probability reasoning.",
        "step_by_step": [
          "Let K = knows, G = guesses.",
          "P(K)=0.5, P(G)=0.5.",
          "P(correct|K)=1, P(correct|G)=0.25.",
          "Total correct = 0.5*1 + 0.5*0.25 = 0.625.",
          "P(K|correct)=0.5/0.625=4/5."
        ],
        "why_correct": {
          "D": "Correct Bayesian update."
        },
        "why_incorrect": {
          "A": "Overestimates.",
          "B": "Incorrect calculation.",
          "C": "Partial probability."
        }
      }
    },
