    "question_text": "In MS Excel, which type of cell reference remains constant when copied across rows and columns?",
    "options": [
      {
        "id": "A",
        "text": "Relative reference"
      },
      {
        "id": "B",
        "text": "Mixed reference"
      },
      {
        "id": "C",
        "text": "Absolute reference"
      },
      {
        "id": "D",
        "text": "Dynamic reference"
      }
    ],
    "correct_option": "C",
    "solution": {
      "final_answer": "Absolute reference",
      "explanation": {
        "concept": "Cell references in Excel determine how formulas behave when copied. Absolute references use '$' to lock both row and column.",
        "step_by_step": [
          "Relative references change based on position.",
          "Mixed references lock either row or column.",
          "Absolute references lock both row and column using '$'.",
          "Thus, absolute reference remains constant."
        ],
        "why_correct": {
          "A": "Incorrect because relative references change when copied.",
          "B": "Incorrect because mixed references only partially lock.",
          "C": "Correct because absolute references remain fixed.",
          "D": "Incorrect because dynamic reference is not a valid Excel type."
        },
        "why_incorrect": {
          "A": "Changes when copied.",
          "B": "Only partially constant.",
          "D": "Not a standard Excel concept."
        }
      }
