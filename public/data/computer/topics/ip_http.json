    "question_text": "In IPv4, what is the total number of usable host addresses in a subnet with mask 255.255.255.192?",
    "options": [
      {
        "id": "A",
        "text": "62"
      },
      {
        "id": "B",
        "text": "64"
      },
      {
        "id": "C",
        "text": "126"
      },
      {
        "id": "D",
        "text": "30"
      }
    ],
    "correct_option": "A",
    "solution": {
      "final_answer": "62",
      "explanation": {
        "concept": "Subnetting divides networks. Usable hosts = 2^n - 2, where n = host bits.",
        "step_by_step": [
          "Mask 255.255.255.192 = /26.",
          "Host bits = 6.",
          "Total addresses = 2^6 = 64.",
          "Usable = 64 - 2 = 62."
        ],
        "why_correct": {
          "A": "62 usable hosts after excluding network and broadcast."
        },
        "why_incorrect": {
          "B": "Includes reserved addresses.",
          "C": "Incorrect host calculation.",
          "D": "Applies to /27 subnet."
        }
      }
    },
