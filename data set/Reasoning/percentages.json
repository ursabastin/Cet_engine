  {
    "id": "RSN-PER-029",
    "subject": "reasoning",
    "topic": "percentages",
    "subtopic": "population_growth",
    "question": "The population of a town is 10,000. It increases by 10% annually. What will be the population after 2 years?",
    "options": {
      "A": "12,500",
      "B": "12,000",
      "C": "11,100",
      "D": "12,100"
    },
    "answer": "D",
    "explanation": "Using compound interest formula: P(1 + R/100)^T = 10000(1.1)^2 = 10000 * 1.21 = 12,100.",
    "difficulty": "medium",
