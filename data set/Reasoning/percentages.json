  {
    "id": "RSN-PER-017",
    "subject": "reasoning",
    "topic": "percentages",
    "subtopic": "successive_percent_change",
    "question": "The salary of a person is first increased by 20% and then decreased by 20%. What is the net change in his salary?",
    "options": {
      "A": "2% decrease",
      "B": "No change",
      "C": "4% increase",
      "D": "4% decrease"
    },
    "answer": "D",
    "explanation": "Net change formula = x + y + (xy/100). Here +20 and -20. Net = 20 - 20 + (20*-20)/100 = -400/100 = -4%. Hence 4% decrease.",
    "difficulty": "easy",
    "priority": "high",
    "frequency": "2-3/shift",
    "year_seen": [
      "2024",
      "2025"
    ],
    "tags": [
      "reasoning",
      "percentages",
      "math"
    ],
