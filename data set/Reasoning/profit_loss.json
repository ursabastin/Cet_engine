  {
    "id": "RSN-PL-001",
    "subject": "reasoning",
    "topic": "profit_loss",
    "subtopic": "find_profit_percent",
    "question": "A man buys an article for Rs. 400 and sells it for Rs. 500. What is his profit percentage?",
    "options": {
      "A": "20%",
      "B": "25%",
      "C": "15%",
      "D": "30%"
    },
    "answer": "B",
    "explanation": "Profit = 500 - 400 = 100. Profit % = (100 / 400) * 100 = 25%.",
    "difficulty": "easy",
    "priority": "high",
    "frequency": "2-3/shift",
