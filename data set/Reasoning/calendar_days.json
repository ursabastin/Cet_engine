    "id": "RSN-CAL-015",
    "subject": "reasoning",
    "topic": "calendar_days",
    "subtopic": "leap_year_rules",
    "question": "Which of the following is not a leap year?",
    "options": {
      "A": "2024",
      "B": "2000",
      "C": "1900",
      "D": "1996"
    },
    "answer": "C",
    "explanation": "A century year is a leap year only if it is divisible by 400. 1900 is divisible by 4 but not by 400, so it is not a leap year.",
