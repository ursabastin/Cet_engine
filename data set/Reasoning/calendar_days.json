    "subject": "reasoning",
    "topic": "calendar_days",
    "subtopic": "days_between_dates",
    "question": "How many days are there from 26th January 2024 to 15th May 2024 (both days included)?",
    "options": {
      "A": "110",
      "B": "111",
      "C": "112",
      "D": "113"
    },
    "answer": "B",
    "explanation": "Jan: 6 days (31-26+1). Feb: 29 days (2024 is a leap year). March: 31 days. April: 30 days. May: 15 days. Total = 6+29+31+30+15 = 111.",
    "difficulty": "medium",
