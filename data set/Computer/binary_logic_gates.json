    "id": "CMP-BIN-007",
    "subject": "computer",
    "topic": "binary_logic_gates",
    "subtopic": "binary_to_decimal",
    "question": "Convert the binary number 1010 to decimal.",
    "options": {
      "A": "14",
      "B": "8",
      "C": "10",
      "D": "12"
    },
    "answer": "C",
    "explanation": "1010 in binary = (1 * 2^3) + (0 * 2^2) + (1 * 2^1) + (0 * 2^0) = 8 + 0 + 2 + 0 = 10.",
