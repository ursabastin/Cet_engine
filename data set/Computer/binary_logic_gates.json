  {
    "id": "CMP-BIN-021",
    "subject": "computer",
    "topic": "binary_logic_gates",
    "subtopic": "NAND_gate",
    "question": "The output of a NAND gate is 0 only when:",
    "options": {
      "A": "None of the above",
      "B": "One input is 1 and the other is 0",
      "C": "Both inputs are 0",
      "D": "Both inputs are 1"
    },
    "answer": "D",
    "explanation": "A NAND gate is the inverse of an AND gate. AND gives 1 when both inputs are 1, so NAND gives 0 in that condition.",
